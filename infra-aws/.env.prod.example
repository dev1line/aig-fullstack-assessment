# Copy to .env and fill in values: cp .env.example .env
# Used by deploy/deploy-all.sh when deploying from infra-aws.

# --- Stack names ---
STACK_NETWORK_NAME=my-project-network
STACK_RDS_NAME=my-project-rds
STACK_BACKEND_NAME=my-project-backend
STACK_FRONTEND_NAME=my-project-frontend

# --- RDS (required for first-time deploy) ---
# Master password for PostgreSQL (min 8 chars). Used by deploy-rds.sh.
RDS_MASTER_PASSWORD=YourSecurePassword123

# Optional RDS/DB overrides (defaults in deploy scripts)
# VPC_CIDR=10.0.0.0/16
# DATABASE_NAME=sentiment_reviews
# MASTER_USERNAME=app

# --- Backend / ECS ---
# ECR image URI (optional; script can build and push if not set)
# IMAGE_URI=123456789012.dkr.ecr.ap-southeast-1.amazonaws.com/my-backend:latest
# CORS: deploy-all.sh sets this from CloudFront URL. For manual deploy, set to frontend origin (e.g. https://d123.cloudfront.net).
CORS_ORIGIN=https://d3b1w3vpdvmn7d.cloudfront.net

# --- Frontend ---
# Backend API URL for frontend build (NEXT_PUBLIC_API_URL). Use the API CloudFront distribution (HTTPS), not the ALB (HTTP).
# Backend stack output: ApiDistributionDomainName -> https://<domain>
# Current API distribution: d1cz1vin7a118c.cloudfront.net (origin = ALB)
NEXT_PUBLIC_API_URL=https://d1cz1vin7a118c.cloudfront.net

# --- Optional ---
# PROJECT_NAME=sentiment-app
# AWS_REGION=ap-southeast-1
