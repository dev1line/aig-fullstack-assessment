datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model Review {
  id         String   @id @default(cuid())
  text       String
  sentiment  String
  confidence Float
  positive   Float
  negative   Float
  neutral    Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
