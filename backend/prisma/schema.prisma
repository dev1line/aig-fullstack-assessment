datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

enum Sentiment {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

model Review {
  id         String    @id @default(cuid())
  text       String
  sentiment  Sentiment
  confidence Float
  positive   Float
  negative   Float
  neutral    Float
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([createdAt, id])
}
