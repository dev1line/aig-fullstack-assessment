# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

PORT=3001
# Disable dotenv log when loading (test, natural, …). Set true to avoid "[dotenv@x] injecting env..."
DOTENV_CONFIG_QUIET=true

# PostgreSQL URI
# Local / docker-compose: docker-compose up -d postgres
# DATABASE_URL="postgresql://app:appsecret@localhost:5432/sentiment_reviews"
# RDS (AWS): get via AWS CLI (requires infra-aws/.env with RDS_MASTER_PASSWORD and RDS stack deployed):
#   eval $(./infra-aws/deploy/get-database-url.sh)   # export to shell
#   or run the script and copy the export DATABASE_URL=... line into .env
# RDS: add &uselibpqcompat=true to avoid "self-signed certificate in certificate chain" error
DATABASE_URL="postgresql://app:YOUR_PASSWORD@your-rds.region.rds.amazonaws.com:5432/sentiment_reviews?sslmode=require&uselibpqcompat=true"

# Sentiment tuning (optional)
# 1 = unigrams, 2 = unigrams+bigrams, 3 = +trigrams
SENTIMENT_NGRAM_SIZE=2
# Max rows from datasets/data.csv used for training (startup time vs accuracy)
SENTIMENT_MAX_CSV_TRAINING_ROWS=10000
# Multiplier for top class probability (clamped to 1.0)
SENTIMENT_CONFIDENCE_BOOST=1.2
# Confidence when input is empty (0..1)
SENTIMENT_EMPTY_INPUT_CONFIDENCE=0.5
# Floor confidence for knowledge matches (0..1)
SENTIMENT_KNOWLEDGE_MIN_CONFIDENCE_FLOOR=0.85
# Optional overrides (absolute or relative to backend root)
# SENTIMENT_DATA_CSV_PATH=datasets/data.csv
# SENTIMENT_KNOWLEDGE_PATH=src/sentiment/knowledge/test-cases.json
