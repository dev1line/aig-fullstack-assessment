{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "sentiment/knowledge/*.json", "watchAssets": true },
      { "include": "../datasets/*.csv", "outDir": "dist/datasets", "watchAssets": true }
    ]
  }
}
