{
  "name": "sentiment-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "start:static": "npx serve@latest out -p 3000",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"app/**/*.tsx\" \"components/**/*.tsx\" \"lib/**/*.ts\" \"types/**/*.ts\" \"utils/**/*.ts\" --fix",
    "lint:check": "eslint \"app/**/*.tsx\" \"components/**/*.tsx\" \"lib/**/*.ts\" \"types/**/*.ts\" \"utils/**/*.ts\"",
    "format": "prettier --write \"app/**/*.tsx\" \"components/**/*.tsx\" \"lib/**/*.ts\" \"types/**/*.ts\" \"utils/**/*.ts\"",
    "format:check": "prettier --check \"app/**/*.tsx\" \"components/**/*.tsx\" \"lib/**/*.ts\" \"types/**/*.ts\" \"utils/**/*.ts\""
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "jsdom": "^25.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "prettier": "^3.4.2"
  }
}
